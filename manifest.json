{
  "manifest_version": 3,
  "name": "PUP SIScore",
  "version": "2.0",
  "description": "Auto-select radio button ratings in the PUP Survey evaluation form.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://survey.pup.edu.ph/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PUP SIScore",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://survey.pup.edu.ph/apps/evaluation/survey/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
